---
export const prerender = true;
import BaseLayout from '../layouts/BaseLayout.astro';
import { Header } from '../components/layout/Header';
import { Footer } from '../components/layout/Footer';
import { Container } from '../components/ui';
import TrustBar from '../components/sections/TrustBar';
import PainPoints from '../components/sections/PainPoints';
import CaseStudyPreview from '../components/sections/CaseStudyPreview';
import Services from '../components/sections/Services';
import WhyMe from '../components/sections/WhyMe';
import WorkflowProcess from '../components/sections/WorkflowProcess';
import FeaturedArticles from '../components/sections/FeaturedArticles';
import HomeFAQ from '../components/sections/HomeFAQ';
import InlineContactForm from '../components/sections/InlineContactForm';
---

<BaseLayout
  title="Consultor SEO Chile | Facundo Zupel — Escalá tu negocio orgánicamente"
  description="Consultor SEO en Chile. Asesoría SEO personalizada con SEO técnico, automatizaciones y estrategia data-driven. Caso cliente español del rubro de recambios de auto: +560K€ en facturación orgánica."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Facundo Zupel - Consultor SEO",
      "url": "https://facundogrowth.com",
      "logo": "https://facundogrowth.com/logo.png",
      "sameAs": [
        "https://www.linkedin.com/in/facundo-zupel-b7513916a/"
      ],
      "contactPoint": {
        "@type": "ContactPoint",
        "contactType": "customer service",
        "availableLanguage": "Spanish"
      }
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Facundo Zupel",
      "jobTitle": "Consultor SEO",
      "url": "https://facundogrowth.com",
      "sameAs": [
        "https://www.linkedin.com/in/facundo-zupel-b7513916a/"
      ],
      "knowsAbout": [
        "SEO", "Posicionamiento Web", "SEO Técnico", "Google Analytics 4",
        "Google Search Console", "Python", "Automatización SEO",
        "SEO Ecommerce", "SEO Local", "Keyword Research"
      ],
      "worksFor": {
        "@type": "Organization",
        "name": "Facundo Zupel - Consultor SEO"
      }
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "¿Qué hace un consultor SEO?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Un consultor SEO analiza, planifica y ejecuta estrategias de posicionamiento orgánico para que tu sitio aparezca en Google cuando buscan lo que ofreces. Esto incluye SEO técnico (rastreo e indexación, Core Web Vitals, datos estructurados), estrategia de contenido basada en intención de búsqueda, link building y análisis de rendimiento orgánico con herramientas como Google Search Console y GA4."
          }
        },
        {
          "@type": "Question",
          "name": "¿Cuánto tarda en verse resultados con SEO?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Los primeros resultados técnicos — indexación, corrección de errores — se ven en semanas. Los resultados de posicionamiento y tráfico orgánico se notan entre 3 y 6 meses, dependiendo de la competencia, la autoridad de dominio y el estado inicial del sitio. El SEO genera retornos compuestos: cada mejora suma sobre la anterior."
          }
        },
        {
          "@type": "Question",
          "name": "¿Cuál es la diferencia entre un consultor SEO y una agencia SEO?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Un consultor trabaja directamente contigo, con mayor personalización y profundidad técnica. No hay intermediarios ni rotación de ejecutivos. Yo analizo tu proyecto con Screaming Frog, Semrush y Google Search Console, defino la estrategia y la ejecuto. En una agencia, tu proyecto suele pasar por varias manos y el nivel de detalle se diluye."
          }
        },
        {
          "@type": "Question",
          "name": "¿Trabajas con pymes y pequeñas empresas?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Sí. Trabajo con pymes, empresas medianas y grandes. Para pequeñas empresas, el SEO local y las long-tail keywords suelen ser el punto de partida más rentable. Adapto el alcance del proyecto al presupuesto y objetivos de cada negocio."
          }
        },
        {
          "@type": "Question",
          "name": "¿El SEO funciona para pymes y negocios pequeños?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Sí, y en muchos casos es donde mejor funciona. Las pymes que atienden un área geográfica específica tienen una ventaja natural en el SEO local: compiten en un espacio más acotado que las grandes empresas nacionales. Una consultoría SEO personalizada para pymes se enfoca en Google Business Profile, keywords locales y contenido orientado a conversión. El costo parte desde $200.000/mes y el retorno a mediano plazo supera con creces al de Google Ads."
          }
        },
        {
          "@type": "Question",
          "name": "¿Cuánto cuesta una consultoría SEO?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Depende del alcance: tamaño del sitio, competencia del sector y objetivos. Ofrezco un diagnóstico gratuito donde evaluamos tu situación y te presento una propuesta ajustada."
          }
        },
        {
          "@type": "Question",
          "name": "¿Trabajas con empresas fuera de Chile?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Sí. Trabajo con empresas de Chile, Argentina, Perú y España. El SEO se ejecuta de forma remota sin perder calidad. Lo importante es entender el mercado local de cada cliente y adaptar la estrategia de posicionamiento web a su contexto geográfico."
          }
        },
        {
          "@type": "Question",
          "name": "¿Cómo sé si el posicionamiento web está funcionando?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "A través de métricas concretas: posiciones en Google para tus keywords objetivo, tráfico orgánico, CTR y — lo más importante — leads o ventas generadas desde ese tráfico. Mido todo con Google Analytics 4 y Search Console, y te entrego reportes periódicos con datos reales."
          }
        },
        {
          "@type": "Question",
          "name": "¿El posicionamiento web sirve para cualquier negocio?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Sí, siempre que tus potenciales clientes busquen en Google lo que ofreces. Funciona especialmente bien para servicios profesionales, ecommerce, B2B y negocios locales. En el diagnóstico inicial evaluamos si tiene sentido para tu caso y qué tipo de estrategia es la más rentable."
          }
        }
      ]
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "Facundo Zupel - Consultor SEO Chile",
      "url": "https://facundogrowth.com",
      "description": "Consultoría SEO en Chile. Estrategia de posicionamiento web, SEO técnico, automatización y crecimiento orgánico para empresas y pymes.",
      "publisher": {
        "@type": "Person",
        "name": "Facundo Zupel"
      }
    })} />
  </Fragment>

  <nav slot="header" class="nav_wrapper">
    <Header client:load />
  </nav>

  <!-- HERO -->
  <section class="section_hp-hero" id="inicio">
    <div class="padding-block hp_hero">
      <Container>
        <!-- Eyebrow -->
        <div class="hero-animate-1 inline-flex items-center gap-2 px-4 py-1.5 rounded bg-black/[0.04] border border-black/[0.1] mb-8 hero-eyebrow">
          <span class="w-2 h-2 rounded-full bg-green-500 hero-dot-pulse"></span>
          <span class="text-sm text-black/55">SEO técnico + datos + automatización. Sin humo.</span>
        </div>

        <h1 class="hero-animate-2 text-[#1a1a1a] mb-10 max-w-4xl">
          Consultor SEO Growth: Escala tu negocio <span class="hero-gradient-text">orgánicamente</span>
        </h1>

        <p class="hero-animate-3 text-lg md:text-xl text-black/45 mb-12 leading-relaxed max-w-2xl">
          Hago que tu negocio aparezca en Google y que ese tráfico se convierta en plata real. Posicionamiento orgánico, SEO técnico y automatizaciones para rentabilizar y escalar tu negocio. Si buscás un consultor SEO en Chile u otro país de Latinoamérica, estás en el lugar correcto.
        </p>

        <!-- CTAs -->
        <div class="hero-animate-4 flex flex-col sm:flex-row gap-4">
          <button
            data-open-contact="home_hero"
            class="inline-flex items-center justify-center gap-3 px-8 py-3.5 bg-[#1a1a1a] text-white font-medium rounded hover:bg-black/90 transition-all duration-200 cursor-pointer"
          >
            Agendar Diagnóstico Gratuito
          </button>
          <a
            href="#casos"
            class="hero-cta-secondary inline-flex items-center justify-center gap-3 px-8 py-3.5 border border-black/[0.15] text-[#1a1a1a] font-medium rounded hover:bg-black/[0.03] hover:border-black/[0.2] transition-all duration-200"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
            </svg>
            Ver Resultados Reales
          </a>
        </div>
      </Container>
    </div>
  </section>

  <!-- TRUST BAR -->
  <section class="section_hp-trust">
    <div class="padding-block">
      <TrustBar client:load />
    </div>
  </section>

  <!-- CASO DE ÉXITO (movido arriba para social proof temprana) -->
  <section class="section_hp-cases" id="casos">
    <div class="padding-block">
      <CaseStudyPreview client:load />
    </div>
  </section>

  <!-- ANALIZADOR SEO GRATUITO -->
  <section class="section_hp-analyzer" id="analizador">
    <div class="padding-block">
      <Container>
        <div class="text-center max-w-3xl mx-auto">
          <span class="inline-block text-xs font-mono uppercase tracking-widest text-[#BF551A] mb-4">Herramienta gratuita</span>
          <h2 class="text-3xl md:text-4xl font-bold text-[#1a1a1a] mb-4 tracking-tight">
            Analiz&aacute; el SEO de tu sitio <span class="text-[#BF551A]">en segundos</span>
          </h2>
          <p class="text-lg text-black/45 leading-relaxed mb-8">
            Peg&aacute; tu URL y recib&iacute; un diagn&oacute;stico SEO completo con inteligencia artificial. Gratis, sin registro previo.
          </p>
          <a
            href="/analizador-seo"
            class="inline-flex items-center justify-center gap-3 px-8 py-3.5 bg-[#BF551A] text-white font-medium rounded hover:bg-[#A04716] transition-all duration-200"
          >
            Probar Analizador SEO Gratis
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
            </svg>
          </a>
        </div>
      </Container>
    </div>
  </section>

  <!-- PAIN POINTS -->
  <section class="section_hp-painpoints">
    <div class="padding-block">
      <PainPoints client:load />
    </div>
  </section>

  <!-- SERVICIOS -->
  <section class="section_hp-services">
    <div class="padding-block">
      <Services client:load />
    </div>
  </section>

  <!-- POR QUÉ YO -->
  <section class="section_hp-whyme">
    <div class="padding-block">
      <WhyMe client:load />
    </div>
  </section>

  <!-- PROCESO -->
  <section class="section_hp-process" id="proceso">
    <div class="padding-block">
      <WorkflowProcess client:load />
    </div>
  </section>

  <!-- ARTÍCULOS DESTACADOS -->
  <section class="section_hp-articles">
    <div class="padding-block">
      <FeaturedArticles client:load />
    </div>
  </section>

  <!-- FAQ -->
  <section class="section_hp-faq">
    <div class="padding-block">
      <HomeFAQ client:load />
    </div>
  </section>

  <!-- CONSULTOR SEO CHILE: CONTENIDO ESTÁTICO PARA INDEXACIÓN -->
  <section class="section_hp-seo-content">
    <div class="padding-block">
    <Container>
      <div class="max-w-4xl mx-auto space-y-16">

        <!-- ¿Qué hace un consultor SEO en Chile? -->
        <div>
          <h2 class="text-3xl md:text-4xl font-bold text-[#1a1a1a] mb-6">
            ¿Qué hace un consultor SEO en Chile?
          </h2>
          <div class="space-y-5">
            <p class="text-xl text-black/45 leading-relaxed">
              Un <strong>consultor SEO</strong> analiza, diagnostica y ejecuta estrategias de posicionamiento orgánico para que tu sitio aparezca en Google cuando tus potenciales clientes buscan lo que ofreces. Su trabajo abarca SEO técnico, estrategia de contenido, link building y análisis de rendimiento orgánico con herramientas como Google Search Console y GA4.
            </p>
            <p class="text-xl text-black/45 leading-relaxed">
              La diferencia con una agencia: trabajás directamente conmigo. No hay intermediarios, no hay rotación de ejecutivos. Analizo tu proyecto con Screaming Frog, Semrush y Search Console, defino la <a href="/estrategia-seo" class="text-[#BF551A] hover:text-[#D4763E] transition-colors">estrategia SEO</a> y la ejecuto. Si algo no está funcionando, lo sé de primera mano y lo ajusto.
            </p>
            <p class="text-xl text-black/45 leading-relaxed">
              A eso se suma un perfil técnico diferenciador: <strong>automatizo procesos con Python y agentes de IA</strong>, integro datos de GA4 y Search Console mediante APIs, y uso herramientas de análisis semántico para identificar oportunidades que la competencia no ve. No estoy adivinando — estoy midiendo.
            </p>
          </div>
        </div>

        <!-- ¿Para quién es la consultoría SEO? -->
        <div>
          <h2 class="text-3xl md:text-4xl font-bold text-[#1a1a1a] mb-6">
            ¿Para quién es la consultoría SEO?
          </h2>
          <p class="text-xl text-black/45 leading-relaxed mb-8">
            Trabajo con pymes, ecommerce, empresas que dependen de Google Ads y negocios en fase de crecimiento. Adapto la estrategia al presupuesto y objetivos de cada proyecto.
          </p>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="card p-6 border border-black/[0.1]">
              <h3 class="font-bold text-lg text-[#1a1a1a] mb-3">¿Sos pyme y necesitás más clientes?</h3>
              <p class="text-black/45 leading-relaxed">
                Para negocios que dependen de clientes locales, el SEO es el canal más rentable a mediano plazo. Trabajo <a href="/seo-local-chile" class="text-[#BF551A] hover:text-[#D4763E] transition-colors">estrategias de SEO local</a> y long-tail keywords adaptadas a tu presupuesto. He visto pymes superar a cadenas con 10 veces más presupuesto simplemente por tener su SEO local bien armado.
              </p>
            </div>
            <div class="card p-6 border border-black/[0.1]">
              <h3 class="font-bold text-lg text-[#1a1a1a] mb-3">¿Tenés una tienda online con catálogo grande?</h3>
              <p class="text-black/45 leading-relaxed">
                Ecommerce con catálogos grandes necesitan una estrategia técnica sólida: indexación masiva, schema Product y optimización de categorías. Como <strong>consultor SEO para ecommerce</strong>, trabajo específicamente en estos problemas.
              </p>
            </div>
            <div class="card p-6 border border-black/[0.1]">
              <h3 class="font-bold text-lg text-[#1a1a1a] mb-3">¿Dependés 100% de Google Ads?</h3>
              <p class="text-black/45 leading-relaxed">
                Si todo tu tráfico viene de publicidad paga, estás a un clic de perderlo. El <strong>posicionamiento web orgánico</strong> construye un activo que genera tráfico sin costo por clic. Lo hicimos con cliente español del rubro de recambios de auto y los resultados fueron contundentes: +560.000€ en facturación orgánica en 12 meses.
              </p>
            </div>
            <div class="card p-6 border border-black/[0.1]">
              <h3 class="font-bold text-lg text-[#1a1a1a] mb-3">¿Estás en fase de escalar?</h3>
              <p class="text-black/45 leading-relaxed">
                Si ya tenés producto-mercado fit y necesitás escalar tu adquisición, un acompañamiento SEO mensual te da continuidad para crecer de forma sostenible sin inflar el presupuesto de marketing.
              </p>
            </div>
          </div>
        </div>

        <!-- SEO para pymes -->
        <div>
          <h2 class="text-3xl md:text-4xl font-bold text-[#1a1a1a] mb-6">
            SEO para pymes: cómo competir en Google sin presupuesto de multinacional
          </h2>
          <div class="space-y-5">
            <p class="text-xl text-black/45 leading-relaxed">
              Las <strong>pymes que invierten en SEO</strong> tienen una ventaja que muchas no ven: compiten en un espacio más acotado que las grandes empresas. Mientras una multinacional pelea por keywords genéricas con millones de búsquedas, una pyme puede dominar su nicho local y sus long-tail keywords con una fracción del esfuerzo.
            </p>
            <p class="text-xl text-black/45 leading-relaxed">
              Como <strong>consultor SEO para pymes</strong>, mi enfoque es directo: identifico las búsquedas donde tu negocio puede ganar — no las que suenan bien pero son imposibles de posicionar. Una pyme que vende servicios en Santiago no necesita rankear por "marketing digital" — necesita aparecer en "empresa de [su servicio] en Santiago" con una ficha de Google Business Profile optimizada y contenido que responda exactamente lo que busca su cliente.
            </p>
            <p class="text-xl text-black/45 leading-relaxed">
              El <strong>SEO para pequeñas empresas</strong> arranca con tres pilares: <a href="/seo-local-chile" class="text-[#BF551A] hover:text-[#D4763E] transition-colors">SEO local</a> para capturar búsquedas geográficas, optimización técnica básica para que Google rastree tu sitio sin problemas, y contenido enfocado en intención de compra. El costo parte desde $200.000 CLP/mes y el retorno a mediano plazo supera con creces al de Google Ads — porque el tráfico orgánico no se apaga cuando dejás de pagar.
            </p>
          </div>
        </div>

        <!-- Mi experiencia como consultor SEO -->
        <div>
          <h2 class="text-3xl md:text-4xl font-bold text-[#1a1a1a] mb-6">
            Mi experiencia como consultor SEO
          </h2>
          <div class="space-y-5">
            <p class="text-xl text-black/45 leading-relaxed">
              Más de cinco años trabajando en posicionamiento web, con roles de SEO Manager en agencias como <strong>Dentsu (iProspect)</strong> y <strong>MediaBrands (Kinesso)</strong>. Lideré proyectos de posicionamiento orgánico para marcas como <strong>Nestlé, MetLife, Banco Security y Entel</strong>.
            </p>
            <p class="text-xl text-black/45 leading-relaxed">
              Esa experiencia en agencias me mostró cómo funcionan proyectos SEO a gran escala — y las limitaciones de trabajar con intermediarios. Hoy trabajo como consultor independiente para dedicar toda mi atención técnica a cada proyecto. Sin capas intermedias, sin rotación de equipo. Si querés conocer más sobre mi trayectoria, visitá mi <a href="/quien-soy" class="text-[#BF551A] hover:text-[#D4763E] transition-colors">página de perfil profesional</a>.
            </p>
          </div>
        </div>

        <!-- Consultor SEO para Ecommerce -->
        <div>
          <h2 class="text-3xl md:text-4xl font-bold text-[#1a1a1a] mb-6">
            Consultor SEO para Ecommerce
          </h2>
          <div class="space-y-5">
            <p class="text-xl text-black/45 leading-relaxed">
              Un ecommerce tiene desafíos que el SEO genérico no resuelve: miles de URLs, faceted navigation, contenido duplicado y categorías sin optimizar. Como <strong>consultor SEO para ecommerce</strong>, trabajo en arquitectura, canonical tags, schema Product y estrategia de categorías. El caso más claro: un <strong>cliente español del rubro de recambios de auto</strong> pasó de 25.000 a 301.000 páginas indexadas con +560.000€ en facturación orgánica en 12 meses. Trabajo con Shopify, WooCommerce, PrestaShop, Magento, VTEX y soluciones custom.
            </p>
          </div>
        </div>

        <!-- Consultor SEO vs agencia -->
        <div>
          <h2 class="text-3xl md:text-4xl font-bold text-[#1a1a1a] mb-6">
            ¿Consultor SEO o agencia?
          </h2>
          <p class="text-xl text-black/45 leading-relaxed">
            En una agencia, tu cuenta pasa por coordinadores, analistas junior y account managers. En una <strong>consultoría SEO</strong> personalizada, el especialista que diagnosticó tu sitio es el mismo que define la estrategia y la ejecuta. Como <strong>consultor SEO en Chile</strong> con perfil técnico, trabajo con empresas en Chile, Argentina, España y Perú. <strong>Asesoría SEO</strong> basada en datos, no en suposiciones.
          </p>
        </div>

      </div>
    </Container>
    </div>
  </section>

  <!-- CTA FINAL -->
  <section class="section_hp-cta" id="contacto">
    <div class="padding-block">
    <Container>
      <div class="text-center max-w-3xl mx-auto">
        <h2 class="text-[#1a1a1a] mb-6">
          ¿Querés saber qué oportunidades tiene tu sitio?
        </h2>
        <p class="text-xl text-black/45 mb-10 leading-relaxed">
          En 30 minutos analizo tu situación actual y te muestro exactamente dónde estás dejando tráfico y plata sobre la mesa. Sin compromiso, sin humo.
        </p>

        <!-- CTAs -->
        <div class="flex flex-col sm:flex-row gap-4 justify-center mb-10">
          <button
            data-open-contact="home_final_cta"
            class="inline-flex items-center justify-center gap-3 px-10 py-4 bg-[#1a1a1a] text-white font-medium rounded-lg hover:bg-black/90 transition-all duration-200 cursor-pointer text-lg"
          >
            Agendar Diagnóstico Gratuito
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
            </svg>
          </button>
          <a
            href="/quien-soy"
            class="inline-flex items-center justify-center gap-2 px-10 py-4 border border-black/[0.15] text-[#1a1a1a] font-medium rounded-lg hover:bg-black/[0.03] hover:border-black/[0.2] transition-all duration-200 text-lg"
          >
            Conocer más sobre mí
          </a>
        </div>

        <!-- Trust indicators -->
        <div class="flex flex-wrap justify-center gap-8 text-white/60 text-sm">
          <span class="flex items-center gap-2">
            <svg class="w-4 h-4 text-white/70" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
            </svg>
            Sin compromiso
          </span>
          <span class="flex items-center gap-2">
            <svg class="w-4 h-4 text-white/70" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
            </svg>
            30 minutos
          </span>
          <span class="flex items-center gap-2">
            <svg class="w-4 h-4 text-white/70" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
            </svg>
            100% enfocado en tu negocio
          </span>
        </div>

        <!-- Inline form: baja fricción -->
        <div class="mt-6">
          <p class="text-white/40 text-sm mb-2">¿Preferís dejar tus datos directo?</p>
          <InlineContactForm client:load />
        </div>
      </div>
    </Container>
