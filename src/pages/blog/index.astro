---
export const prerender = true;
import BaseLayout from '@/layouts/BaseLayout.astro';
import { Container } from '@/components/ui';
import { BlogTagFilter } from '@/components/blog';
import { Header } from '@/components/layout/Header';
import { Footer } from '@/components/layout/Footer';
import { getCollection } from 'astro:content';

// Get all blog posts from content collections
const allPosts = await getCollection('blog');

// Filter out drafts and sort by date (most recent first)
const publishedPosts = allPosts
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

// Top 5 by GSC clicks + Clarity engagement (updated 2026-04-10)
const featuredSlugs = [
  'claude-code-seo',
  'claude-code-skills-seo',
  'claude-code-ollama',
  'caso-exito-seo-moda-argentina',
  'mcp-servers-seo',
];

const featuredPosts = featuredSlugs
  .map((slug) => publishedPosts.find((p) => p.slug === slug || p.id.replace(/\.md$/, '') === slug))
  .filter(Boolean)
  .map((post) => ({
    ...post!.data,
    slug: post!.slug || post!.id.replace(/\.md$/, ''),
  }));

const sortedPosts = publishedPosts.map((post) => ({
  ...post.data,
  slug: post.slug,
}));

---

<BaseLayout
  title="Blog | Facundo Zupel - Organic Growth y Automatizaciones"
  description="Artículos sobre crecimiento orgánico, automatizaciones empresariales, SEO, análisis de datos y estrategias de marketing digital."
>
  <Header slot="header" client:load />
  <Footer slot="footer" client:load />

  <!-- Hero del Blog -->
  <section class="pt-32 pb-12 md:pb-16">
    <Container size="xl">
      <div class="text-center max-w-3xl mx-auto">
        <h1 class="text-[#1a1a1a] mb-4">Blog</h1>
        <p class="text-lg md:text-xl text-black/45 leading-relaxed">
          Aprende estrategias, técnicas y casos prácticos sobre <strong
            class="text-[#1a1a1a]">crecimiento orgánico</strong
          >, <strong>automatizaciones</strong> y <strong
            class="text-[#1a1a1a]">análisis de datos</strong
          > para escalar tu negocio.
        </p>
      </div>
    </Container>
  </section>

  <!-- Featured Posts -->
  <section class="pb-16 md:pb-20">
    <Container size="xl">
      <h2 class="text-sm font-mono uppercase tracking-widest text-[#BF551A] mb-6">Artículos destacados</h2>
      <!-- Hero featured: first post large -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
        {featuredPosts.slice(0, 1).map((post) => (
          <a href={`/blog/${post.slug}`} class="group block p-8 md:p-10 border border-black/[0.1] rounded-xl hover:border-[#BF551A]/30 transition-all duration-200 md:col-span-2">
            <span class="inline-block px-3 py-1 text-xs font-medium bg-[#BF551A]/10 text-[#D4763E] rounded-md mb-4">
              {post.category === 'ia-en-seo' ? 'IA en SEO' : 'Todo sobre SEO'}
            </span>
            <h3 class="text-2xl md:text-3xl font-bold text-[#1a1a1a] group-hover:text-[#BF551A] transition-colors mb-3">
              {post.title}
            </h3>
            <p class="text-base text-black/45 leading-relaxed line-clamp-3 max-w-3xl">
              {post.description}
            </p>
          </a>
        ))}
      </div>
      <!-- Remaining 4 featured posts -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-12">
        {featuredPosts.slice(1).map((post) => (
          <a href={`/blog/${post.slug}`} class="group block p-6 border border-black/[0.1] rounded-xl hover:border-[#BF551A]/30 transition-all duration-200">
            <span class="inline-block px-3 py-1 text-xs font-medium bg-[#BF551A]/10 text-[#D4763E] rounded-md mb-4">
              {post.category === 'ia-en-seo' ? 'IA en SEO' : 'Todo sobre SEO'}
            </span>
            <h3 class="text-lg font-bold text-[#1a1a1a] group-hover:text-[#BF551A] transition-colors mb-2 line-clamp-2">
              {post.title}
            </h3>
            <p class="text-sm text-black/45 leading-relaxed line-clamp-2">
              {post.description}
            </p>
          </a>
        ))}
      </div>
      <div class="h-px bg-black/[0.08]"></div>
    </Container>
  </section>

  <!-- Todos los artículos -->
  <section class="py-20 md:py-28">
    <Container size="xl">
      {
        sortedPosts.length === 0 ? (
          <div class="text-center py-16">
            <p class="text-xl text-black/35">
              Próximamente publicaremos nuevos artículos.
            </p>
          </div>
        ) : (
          <BlogTagFilter posts={sortedPosts} client:load />
        )
      }
    </Container>
  </section>

  <!-- CTA final -->
  <section class="py-20 md:py-28">
    <Container size="lg">
      <div class="max-w-3xl mx-auto text-center card p-8 md:p-12">
        <h2 class="text-[#1a1a1a] mb-4">
          No te pierdas los próximos artículos
        </h2>
        <p class="text-lg text-black/45 mb-8">
          Suscribite al feed RSS para recibir artículos sobre SEO, automatizaciones e IA apenas se publiquen.
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <a
            href="/rss.xml"
            target="_blank"
            class="inline-flex items-center gap-2 px-8 py-3.5 bg-[#BF551A] text-white font-medium rounded-lg hover:bg-[#A04716] transition-all duration-200"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M6.18 15.64a2.18 2.18 0 010 4.36 2.18 2.18 0 010-4.36M4 4.44A15.56 15.56 0 0119.56 20h-2.83A12.73 12.73 0 004 7.27V4.44m0 5.66a9.9 9.9 0 019.9 9.9h-2.83A7.07 7.07 0 004 12.93v-2.83z"/>
            </svg>
            Suscribirse via RSS
          </a>
          <button
            data-open-contact
            class="inline-flex items-center gap-2 px-8 py-3.5 border border-black/[0.15] text-[#1a1a1a] font-medium rounded-lg hover:bg-black/[0.03] hover:border-black/[0.2] transition-all duration-200 cursor-pointer"
          >
            Contactar
          </button>
        </div>
      </div>
    </Container>
  </section>
</BaseLayout>
