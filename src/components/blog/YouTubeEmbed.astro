---
interface Props {
  videoId: string;
  title: string;
}

const { videoId, title } = Astro.props;
const thumbnailUrl = `https://i.ytimg.com/vi/${videoId}/maxresdefault.jpg`;
const fallbackUrl = `https://i.ytimg.com/vi/${videoId}/hqdefault.jpg`;
const embedUrl = `https://www.youtube-nocookie.com/embed/${videoId}?autoplay=1`;
---

<div
  class="yt-facade"
  data-video-id={videoId}
  data-embed-url={embedUrl}
  style="aspect-ratio: 16/9; position: relative; cursor: pointer; overflow: hidden; border: 1px solid rgba(0,0,0,0.1); background: #000;"
>
  <img
    src={thumbnailUrl}
    alt={`Video: ${title}`}
    loading="lazy"
    style="width: 100%; height: 100%; object-fit: cover; display: block;"
    onerror={`this.onerror=null;this.src='${fallbackUrl}'`}
  />
  <button
    aria-label={`Reproducir video: ${title}`}
    style="position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; background: none; border: none; cursor: pointer; padding: 0;"
  >
    <span
      class="yt-play-btn"
      style="width: 68px; height: 68px; background: #BF551A; border-radius: 50%; display: flex; align-items: center; justify-content: center; transition: transform 0.2s ease;"
    >
      <svg width="28" height="28" viewBox="0 0 24 24" fill="white" style="margin-left: 3px;">
        <path d="M8 5v14l11-7z" />
      </svg>
    </span>
  </button>
</div>

<style>
  .yt-facade:hover .yt-play-btn {
    transform: scale(1.1);
  }
</style>

<script>
  document.querySelectorAll('.yt-facade').forEach((facade) => {
    facade.addEventListener('click', function () {
      const embedUrl = this.getAttribute('data-embed-url');
      if (!embedUrl) return;
      const iframe = document.createElement('iframe');
      iframe.src = embedUrl;
      iframe.title = 'YouTube video';
      iframe.allow = 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture';
      iframe.allowFullscreen = true;
      iframe.style.cssText = 'position:absolute;inset:0;width:100%;height:100%;border:0;';
      this.innerHTML = '';
      this.style.cursor = 'default';
      this.appendChild(iframe);
    }, { once: true });
  });
</script>
